# ─────────────────────────────────────────────────────────────
# NEXFLOW — variáveis de ambiente (copie para apps/web/.env.local)
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"   # chave publishable/anon — segura no client

# Service role — SOMENTE server-side (seed, jobs). NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxx"

# URL pública do site (callbacks de auth, links de e-mail)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# URL do app autenticado (usada pelos CTAs da landing apps/marketing)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL da landing pública (links de Termos/Privacidade no app)
NEXT_PUBLIC_MARKETING_URL="https://nexflow.com.br"

# ── Cobrança (Iugu — Sprint 3) ──
IUGU_API_TOKEN=""          # sandbox primeiro; troque p/ produção no go-live
IUGU_ACCOUNT_ID=""
IUGU_WEBHOOK_TOKEN=""      # mesmo valor no ?token= do webhook na Iugu

# ── Integrações (Sprint 5) — tudo env-gated; vazio = "modo de configuração" ──
# WhatsApp (Z-API)
ZAPI_INSTANCE=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""
# NF-e de serviço (NFe.io) — usado pela Edge Function billing-webhook
NFEIO_API_KEY=""
NFEIO_COMPANY_ID=""
NFEIO_SERVICE_CODE=""
# Assinatura digital (ClickSign)
CLICKSIGN_TOKEN=""
CLICKSIGN_ENV="sandbox"   # sandbox | production

# ── Transacional / monitoramento ──
RESEND_API_KEY=""
SENTRY_DSN=""
