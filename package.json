{
  "name": "nexflow",
  "version": "0.1.0",
  "private": true,
  "description": "NEXFLOW — CRM + ERP para empresas de engenharia elétrica e automação industrial",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/fix-native-binary-perms.cjs",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start --filter=@nexflow/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:types": "supabase gen types typescript --local > packages/db/src/database.types.ts"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
